### Possgres configuration
PG_USER=postgres
PG_PASSWORD=secret

### Original DB configuration
PG_DATABASE_ORIGINAL_DB=original_db
PG_PORT_ORIGINAL_DB=5432

### Auth DB configuration
PG_DATABASE_AUTH_DB=auth_db
PG_PORT_AUTH_DB=5433

### Core DB configuration
PG_DATABASE_CORE_DB=core_db
PG_PORT_SHARD_1=5434
PG_PORT_SHARD_2=5435

### Redis configuration
REDIS_PORT=6379

### Kafka configuration
KAFKA_BROKER_ID=1
KAFKA_CLIENT_PORT=9092
KAFKA_CONTROLLER_PORT=9093
KAFKA_LISTENERS=PLAINTEXT://:${KAFKA_CLIENT_PORT},CONTROLLER://:${KAFKA_CONTROLLER_PORT}
KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://kafka:${KAFKA_CLIENT_PORT}
# KAFKA_ADVERTISED_LISTENERS=PLAINTEXT://localhost:${KAFKA_CLIENT_PORT}